{
  "name": "writing-copilot",
  "type": "module",
  "version": "0.0.1",
  "description": "Writing Copilot - Phase 0 skeleton",
  "scripts": {
    "dev:api": "bun run db:migrate && bun run src/api/server.ts",
    "dev:web": "cd web && bun run dev",
