    "vite": "^8.0.16",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/bun": "latest",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "playwright": "^1.59.1",
    "typescript": "^5.3.0"
  }
